<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_speed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 km/h"
        android:textColor="#00E676"
        android:textSize="80sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_regen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Regen: --"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tv_battery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="SOC: --%"
            android:textColor="#03A9F4"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tv_range"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Range: --km"
            android:textColor="#E91E63"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tv_brake"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="RELEASED"
            android:textColor="#4CAF50"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Module 7: Canbus -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:id="@+id/tv_canbus_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Canbus: --"
                android:textColor="#FFEB3B"
                android:textSize="12sp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="5dp"
                android:background="#1E1E1E"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tv_canbus_debug_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Waiting..."
                    android:textColor="#AAAAAA"
                    android:textSize="10sp" />
            </ScrollView>
        </LinearLayout>

        <!-- Module 0: Driving -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:id="@+id/tv_driving_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Driving: --"
                android:textColor="#FFEB3B"
                android:textSize="12sp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="5dp"
                android:background="#1E1E1E"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tv_driving_debug_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Waiting..."
                    android:textColor="#AAAAAA"
                    android:textSize="10sp" />
            </ScrollView>
        </LinearLayout>

        <!-- Module 5: Tracking -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:id="@+id/tv_module5_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Module 5: --"
                android:textColor="#FFEB3B"
                android:textSize="12sp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="5dp"
                android:background="#1E1E1E"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tv_module5_debug_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Waiting..."
                    android:textColor="#AAAAAA"
                    android:textSize="10sp" />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
