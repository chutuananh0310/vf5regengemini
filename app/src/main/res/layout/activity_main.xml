<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Top Bar: Thông số quan trọng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="2dp">

        <TextView
            android:id="@+id/tv_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 km/h"
            android:textColor="#00E676"
            android:textSize="40sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_brake"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="RELEASED"
            android:textColor="#4CAF50"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SOC: --%"
            android:textColor="#03A9F4"
            android:textSize="18sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_explorer_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#333333"
        android:padding="2dp"
        android:text="Scanning Modules 21-500..."
        android:textColor="#FFEB3B"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Cột 1: Driving Module 0 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingRight="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Driving (Mod 0)"
                android:textColor="#00E676"
                android:textSize="12sp"
                android:gravity="center"
                android:background="#222222"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000">
                <TextView
                    android:id="@+id/tv_driving_debug_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Waiting for D0..."
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:padding="2dp"/>
            </ScrollView>
        </LinearLayout>

        <!-- Cột 2: Auto Scanner 21-500 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scanner (Mod 21-500)"
                android:textColor="#00E5FF"
                android:textSize="12sp"
                android:gravity="center"
                android:background="#222222"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000">
                <TextView
                    android:id="@+id/tv_explorer_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Initializing scan..."
                    android:textColor="#00E5FF"
                    android:textSize="13sp"
                    android:padding="2dp"/>
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

    <!-- View ẩn tương thích code cũ -->
    <View android:id="@+id/tv_canbus_status" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/tv_canbus_debug_log" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/tv_driving_status" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/tv_module5_status" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/tv_module5_debug_log" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/tv_regen" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/tv_range" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/tv_module_status" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/tv_scanner_log" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <ListView android:id="@+id/lv_module_selector" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <Button android:id="@+id/btn_toggle_explorer" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

</LinearLayout>
