<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Khu vực hiển thị thông số chính -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 km/h"
            android:textColor="#00E676"
            android:textSize="50sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_brake"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="30dp"
            android:text="RELEASED"
            android:textColor="#4CAF50"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_regen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Regen: --"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_battery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="SOC: --%"
            android:textColor="#03A9F4"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_range"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Range: --km"
            android:textColor="#E91E63"
            android:textSize="16sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_module_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#333333"
        android:padding="2dp"
        android:text="Modules Found: ..."
        android:textColor="#FFEB3B"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <!-- Cột 1: Driving Module 0 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Driving (Mod 0)"
                android:textColor="#00E676"
                android:textSize="12sp"
                android:gravity="center"
                android:background="#222222"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#1E1E1E">
                <TextView
                    android:id="@+id/tv_driving_debug_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Waiting for D0..."
                    android:textColor="#AAAAAA"
                    android:textSize="11sp" />
            </ScrollView>
        </LinearLayout>

        <!-- Cột 2: Global Scanner -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scanner (Mod 1-20)"
                android:textColor="#00E5FF"
                android:textSize="12sp"
                android:gravity="center"
                android:background="#222222"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#1E1E1E">
                <TextView
                    android:id="@+id/tv_scanner_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Waiting for data..."
                    android:textColor="#00E5FF"
                    android:textSize="11sp" />
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

    <!-- Các view ẩn để tương thích code cũ -->
    <View android:id="@+id/tv_canbus_status" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/tv_canbus_debug_log" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/tv_driving_status" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/tv_module5_status" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/tv_module5_debug_log" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

</LinearLayout>
